# ===========================================================================
# Backend (FastAPI) environment — copy to `.env` for local (non-docker) runs.
# When running via docker-compose, values come from the root .env instead.
# ===========================================================================
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# --- Security ---
SECRET_KEY=change-me-openssl-rand-hex-32
JWT_SECRET_KEY=change-me-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-fernet-generate-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Database (local host defaults) ---
POSTGRES_USER=aiads
POSTGRES_PASSWORD=aiads
POSTGRES_DB=ai_ads_agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Google OAuth / Ads ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- AI provider ---
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@ai-ads-agent.local

# --- Observability ---
SENTRY_DSN=
