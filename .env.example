# ===========================================================================
# AI Ads Agent — root environment (consumed by docker-compose)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ===========================================================================

# --- Global ---------------------------------------------------------------
ENVIRONMENT=local
COMPOSE_PROJECT_NAME=ai-ads-agent

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=aiads
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ai_ads_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Backend (FastAPI) ----------------------------------------------------
BACKEND_PORT=8000
SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
# 32-byte urlsafe base64 key for Fernet token encryption at rest
ENCRYPTION_KEY=generate-with-python-fernet-generate-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Google OAuth / Ads ---------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- AI provider (OpenAI-compatible) --------------------------------------
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o

# --- Email (reports/notifications) ----------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@ai-ads-agent.local

# --- Frontend -------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=AI Ads Agent
